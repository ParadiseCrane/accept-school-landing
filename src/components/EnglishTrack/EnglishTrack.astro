---
import SectionLabel from "../SectionLabel.astro";
import CodePreview from "./CodePreview.astro";

import { getEntry } from "astro:content";
import type { EnglishSectionData } from "../../content/sections/english.schema";

const entry = await getEntry("englishSection", "english");
if (!entry) throw new Error("Missing sections/english.md");

const content = entry.data as EnglishSectionData;
---

<section class="english-track section" id="english">
  <div class="container">
    <div class="english-shell">
      <div class="english-content">
        <div class="english-info">
          <div class="section-header english-header">
            <SectionLabel label={content.label} />
            <h2>{content.title}</h2>
            <p>{content.description}</p>
          </div>

          <div class="english-benefits">
            {
              content.items.map((item) => (
                <div class="benefit-item">
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>
              ))
            }
          </div>
        </div>

        <div class="english-preview">
          <CodePreview />

          <div class="english-note surface-card">
            <span>Track highlight</span>
            <strong>Программирование и язык в одном рабочем контексте</strong>
            <p>
              Такой формат делает предложение заметно более отличимым: вы
              прокачиваете не только технический навык, но и среду, в которой
              этот навык потом используется.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .english-track {
    position: relative;
    overflow: hidden;
  }

  .english-track::before {
    content: "";
    position: absolute;
    inset: 6% auto auto 64%;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12), transparent 68%);
    filter: blur(14px);
    pointer-events: none;
  }

  .english-shell {
    border-radius: 34px;
    border: 1px solid var(--border);
    padding: 2.4rem;
    background:
      radial-gradient(circle at top right, rgba(129, 140, 248, 0.1), transparent 24%),
      linear-gradient(180deg, rgba(8, 16, 25, 0.96), rgba(7, 14, 22, 0.92));
    box-shadow: var(--shadow-card);
  }

  .english-content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.95fr);
    gap: 3rem;
    align-items: center;
  }

  .english-header {
    text-align: left;
    margin-bottom: 1.5rem;
  }

  .english-header p {
    margin-left: 0;
    margin-right: 0;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .english-signals {
    display: grid;
    gap: 0.85rem;
    margin-bottom: 1.5rem;
  }

  .english-signal {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.9rem;
    align-items: start;
    padding: 1rem 1.1rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .english-signal span,
  .english-note span {
    color: var(--primary-light);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .english-signal p {
    color: var(--text-soft);
    line-height: 1.65;
  }

  .english-benefits {
    display: grid;
    gap: 1rem;
  }

  .benefit-item {
    padding: 1.2rem 1.3rem;
    border-radius: 22px;
    background: rgba(129, 140, 248, 0.08);
    border: 1px solid rgba(129, 140, 248, 0.16);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      background 0.3s ease;
  }

  .benefit-item:hover {
    transform: translateX(6px);
    border-color: rgba(125, 249, 230, 0.24);
    background: rgba(129, 140, 248, 0.12);
  }

  .benefit-item h3 {
    margin-bottom: 0.5rem;
    font-size: 1.15rem;
  }

  .benefit-item p {
    color: var(--text-muted);
    line-height: 1.7;
  }

  .english-preview {
    display: grid;
    gap: 1rem;
  }

  .english-note {
    padding: 1.25rem;
    border-radius: 24px;
  }

  .english-note strong {
    display: block;
    font-size: 1.15rem;
    margin: 0.65rem 0;
  }

  .english-note p {
    color: var(--text-muted);
    line-height: 1.75;
  }

  @media (width < 1024px) {
    .english-content {
      grid-template-columns: 1fr;
    }
  }

  @media (width < 768px) {
    .english-shell {
      padding: 1.2rem;
      border-radius: 24px;
    }

    .english-signal,
    .benefit-item,
    .english-note {
      padding: 1rem;
    }
  }
</style>
