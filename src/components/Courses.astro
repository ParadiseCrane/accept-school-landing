<script>
  function createBars(containerId: any) {
    const container = document.getElementById(containerId);
    if (!container) return null;

    const heights = [60, 140, 90, 200, 170, 100, 190, 120, 180, 80];
    container.innerHTML = "";

    heights.forEach((height) => {
      const bar = document.createElement("div");
      bar.className = "bar";
      bar.style.height = height + "px";
      container.appendChild(bar);
    });

    return {
      bars: container.querySelectorAll(".bar"),
      heights: [...heights],
    };
  }

  async function bubbleSortAnimation(containerId: any) {
    const result = createBars(containerId);
    if (!result) return;

    const { bars, heights } = result;
    const n = heights.length;

    for (let i = 0; i < n; i++) {
      for (let j = 0; j < n - i - 1; j++) {
        bars[j].classList.add("comparing");
        bars[j + 1].classList.add("comparing");

        await new Promise((resolve) => setTimeout(resolve, 400));

        if (heights[j] > heights[j + 1]) {
          [heights[j], heights[j + 1]] = [heights[j + 1], heights[j]];
          // @ts-expect-error
          bars[j].style.height = heights[j] + "px";
          // @ts-expect-error
          bars[j + 1].style.height = heights[j + 1] + "px";
        }

        bars[j].classList.remove("comparing");
        bars[j + 1].classList.remove("comparing");
      }
      bars[n - i - 1].classList.add("sorted");
      await new Promise((resolve) => setTimeout(resolve, 200));
    }

    await new Promise((resolve) => setTimeout(resolve, 2000));
    setTimeout(() => bubbleSortAnimation(containerId), 1000);
  }

  // Terminal Animation
  const terminalSequences = [
    [
      { text: "$ ", class: "prompt", delay: 0 },
      { text: "uv init modern-python", class: "command", delay: 60 },
      { text: "\n", delay: 600 },
      { text: "✓ Initialized project\n\n", class: "success", delay: 40 },
      { text: "$ ", class: "prompt", delay: 500 },
      { text: "uv add fastapi uvicorn", class: "command", delay: 60 },
      { text: "\n", delay: 600 },
      { text: "✓ Dependencies installed\n\n", class: "success", delay: 40 },
      { text: "$ ", class: "prompt", delay: 500 },
      { text: "uv run python app.py", class: "command", delay: 60 },
      { text: "\n", delay: 900 },
      {
        text: "⚡ Server running at http://127.0.0.1:8000",
        class: "output",
        delay: 40,
      },
    ],
    [
      { text: "$ ", class: "prompt", delay: 0 },
      { text: "ruff check .", class: "command", delay: 60 },
      { text: "\n", delay: 600 },
      { text: "✓ All checks passed\n\n", class: "success", delay: 40 },
      { text: "$ ", class: "prompt", delay: 500 },
      { text: "mypy src/", class: "command", delay: 60 },
      { text: "\n", delay: 600 },
      {
        text: "✓ Success: no issues found\n\n",
        class: "success",
        delay: 40,
      },
      { text: "$ ", class: "prompt", delay: 500 },
      { text: "pytest tests/ -v", class: "command", delay: 60 },
      { text: "\n", delay: 900 },
      { text: "✓ 15 tests passed in 2.3s", class: "output", delay: 40 },
    ],
  ];

  let terminalSeqIndex = 0;

  async function typeTerminal() {
    const body = document.getElementById("terminalBody");
    if (body) {
      body.innerHTML = "";
      const seq = terminalSequences[terminalSeqIndex];

      for (const item of seq) {
        await new Promise((resolve) => setTimeout(resolve, item.delay));

        if (item.text === "\n") {
          body.innerHTML += "<br>";
        } else {
          const span = document.createElement("span");
          span.className = "terminal-line " + item.class;
          body.appendChild(span);

          for (const char of item.text) {
            span.textContent += char;
            await new Promise((resolve) => setTimeout(resolve, item.delay));
          }
        }
      }

      const cursor = document.createElement("span");
      cursor.className = "cursor-blink";
      body.appendChild(cursor);

      await new Promise((resolve) => setTimeout(resolve, 3000));
      body.style.opacity = "0";
      await new Promise((resolve) => setTimeout(resolve, 500));
      body.style.opacity = "1";

      terminalSeqIndex = (terminalSeqIndex + 1) % terminalSequences.length;
      setTimeout(typeTerminal, 500);
    }
  }

  const bubbleFunction = () => {
    bubbleSortAnimation("sortViz");
  };

  // Initialize animations
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", typeTerminal);
    document.addEventListener("DOMContentLoaded", bubbleFunction);
  } else {
    bubbleFunction();
    typeTerminal();
  }
</script>
