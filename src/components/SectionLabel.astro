---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span class="section-label">{label}</span>

<style>
  .section-label {
    display: inline-block;
    background: rgba(99, 102, 241, 0.1);
    color: var(--primary-light);
    padding: 0.5rem 1.5rem;
    border-radius: 30px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1rem;
    border: 1px solid rgba(99, 102, 241, 0.2);
  }
</style>
