---
import Logo from "./Logo.astro";
import { getEntry, type CollectionEntry } from "astro:content";

type NavData = CollectionEntry<"navigation">["data"];

const entry = await getEntry("navigation", "navbar");
if (!entry) throw new Error("Missing entry: src/content/navigation/navbar.md");

const { links: navLinks, cta, aria } = entry.data as NavData;
---

<nav id="navbar">
  <div class="nav-container">
    <Logo stickToRight />

    <button
      id="burger"
      class="burger"
      type="button"
      aria-label="Открыть меню"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>

    <ul class="nav-links">
      {
        navLinks.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))
      }
    </ul>

    <a href="https://t.me/accept_school_bot" class="cta-button cta-desktop"
      >Записаться</a
    >
  </div>

  <div id="menu-backdrop" class="menu-backdrop" aria-hidden="true"></div>

  <div id="mobile-menu" class="mobile-menu" data-open="false">
    <ul class="mobile-links">
      {
        navLinks.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))
      }
    </ul>

    <a href="https://t.me/accept_school_bot" class="cta-button cta-mobile"
      >Записаться</a
    >
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    padding-top: 1rem;
  }

  nav.scrolled .nav-container {
    background: rgba(7, 17, 27, 0.9);
    box-shadow: 0 22px 44px rgba(0, 0, 0, 0.28);
  }

  .nav-container {
    max-width: 1320px;
    margin: 0 auto;
    width: calc(100% - 2rem);
    display: flex;
    justify-content: flex-end;
    align-items: center;
    height: 5.25rem;
    padding: 0 1.5rem;
    backdrop-filter: blur(20px);
    background: rgba(7, 17, 27, 0.72);
    border: 1px solid rgba(226, 232, 240, 0.09);
    border-radius: 999px;
    box-shadow:
      0 10px 40px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    align-items: center;
    padding-right: 2.5rem;
  }

  .nav-links a,
  .mobile-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: color 0.3s ease;
    position: relative;
  }

  .nav-links a:hover,
  .mobile-links a:hover {
    color: var(--text-light);
  }

  .nav-links a::after,
  .mobile-links a::after {
    content: "";
    position: absolute;
    bottom: -7px;
    left: 50%;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--primary-light);
    transform: translateX(-50%) scale(0);
    transition: transform 0.3s ease;
  }

  .nav-links a:hover::after,
  .mobile-links a:hover::after {
    transform: translateX(-50%) scale(1);
  }

  .cta-button {
    background: var(--gradient-1);
    color: white;
    padding: 0.85rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      filter 0.3s ease;
    box-shadow: 0 16px 28px rgba(20, 184, 166, 0.2);
    white-space: nowrap;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 34px rgba(20, 184, 166, 0.3);
    filter: saturate(1.05);
  }

  .cta-button::after {
    display: none;
  }

  .burger {
    display: none;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(226, 232, 240, 0.09);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 0;
  }

  .burger-line {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-light);
    border-radius: 2px;
    transition:
      transform 0.25s ease,
      opacity 0.2s ease;
  }

  .burger.is-open .burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .burger.is-open .burger-line:nth-child(2) {
    opacity: 0;
  }

  .burger.is-open .burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .menu-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
    z-index: 999;
    margin-top: 0;
  }

  .menu-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu {
    position: fixed;
    top: 6.4rem;
    background: rgba(7, 17, 27, 0.88);
    border: 1px solid rgba(226, 232, 240, 0.09);
    backdrop-filter: blur(20px);
    transform: translateY(-8px);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
    z-index: 1000;
    width: min(360px, calc(100% - 2rem));
    right: 1rem;
    max-width: 360px;
    height: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-radius: 28px;
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.28);
  }

  .mobile-menu[data-open="true"] {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0;
  }

  .cta-mobile {
    display: block;
    text-align: center;
  }

  @media (width < 1024px) {
    .nav-links {
      gap: 1rem;
      padding-right: 1.5rem;
    }

    .nav-container {
      padding: 0 1rem;
      width: calc(100% - 1rem);
    }
  }

  @media (width <= 768px) {
    .nav-links {
      display: none;
    }

    .cta-desktop {
      display: none;
    }

    .burger {
      display: inline-flex;
      margin-left: auto;
      flex-direction: column;
    }

    .mobile-menu {
      top: 5rem;
    }
  }
</style>

<script type="module">
  const navbar = document.getElementById("navbar");
  const burger = document.getElementById("burger");
  const mobileMenu = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("menu-backdrop");

  const setBodyScroll = (locked) => {
    document.body.style.overflow = locked ? "hidden" : "";
  };

  const openMenu = () => {
    if (!burger || !mobileMenu || !backdrop) return;
    burger.classList.add("is-open");
    burger.setAttribute("aria-expanded", "true");
    mobileMenu.setAttribute("data-open", "true");
    backdrop.classList.add("is-open");
    setBodyScroll(true);
  };

  const closeMenu = () => {
    if (!burger || !mobileMenu || !backdrop) return;
    burger.classList.remove("is-open");
    burger.setAttribute("aria-expanded", "false");
    mobileMenu.setAttribute("data-open", "false");
    backdrop.classList.remove("is-open");
    setBodyScroll(false);
  };

  const toggleMenu = () => {
    if (!mobileMenu) return;
    const isOpen = mobileMenu.getAttribute("data-open") === "true";
    isOpen ? closeMenu() : openMenu();
  };

  if (navbar) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 100) navbar.classList.add("scrolled");
      else navbar.classList.remove("scrolled");
    });
  }

  if (burger) burger.addEventListener("click", toggleMenu);
  if (backdrop) backdrop.addEventListener("click", closeMenu);

  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth > 768) closeMenu();
  });

  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", function (e) {
      const href = this.getAttribute("href");
      if (!href || href === "#") return;

      const target = document.querySelector(href);
      if (!target) return;

      e.preventDefault();
      closeMenu();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });
</script>
