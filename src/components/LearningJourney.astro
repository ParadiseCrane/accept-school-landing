---
import SectionLabel from "./SectionLabel.astro";

const steps = [
  {
    number: "01",
    title: "Выбираете точку входа",
    description: "Стартуете с нуля или сразу идёте в следующий уровень",
  },
  {
    number: "02",
    title: "Учитесь в живом ритме",
    description: "Теория, разбор и практика работают вместе, а не по отдельности",
  },
  {
    number: "03",
    title: "Закрепляете через платформу",
    description: "Решаете задачи и быстро понимаете, что уже получается",
  },
];

const outcomes = [
  {
    title: "Для новичков",
    description: "Понятный старт без перегруза",
  },
  {
    title: "Для тех, кому нужна системность",
    description: "Сильная база для роста дальше",
  },
  {
    title: "Для тех, кто хочет расти шире",
    description: "English Track и AI усиливают предложение без потери базы",
  },
];
---

<section id="journey" class="section journey">
  <div class="container">
    <div class="journey-shell">
      <div class="journey-intro">
        <SectionLabel label="Как учим" />
        <h2>Формат, в котором легко держать темп</h2>
        <p>Вы выбираете подходящий уровень, работаете через практику и видите прогресс на каждом этапе</p>

        <div class="journey-signals">
          <div>
            <span>01</span>
            <strong>Живой ритм занятий</strong>
          </div>
          <div>
            <span>02</span>
            <strong>Проверка решений без пауз</strong>
          </div>
          <div>
            <span>03</span>
            <strong>Понятная траектория роста</strong>
          </div>
        </div>
      </div>

      <div class="journey-grid">
        {
          steps.map((step) => (
            <article class="journey-step surface-card">
              <span class="journey-step-number">{step.number}</span>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </article>
          ))
        }
      </div>

      <div class="journey-outcomes">
        {
          outcomes.map((outcome) => (
            <article class="journey-outcome">
              <h3>{outcome.title}</h3>
              <p>{outcome.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .journey {
    position: relative;
  }

  .journey-shell {
    position: relative;
    padding: 3rem;
    border-radius: 36px;
    overflow: hidden;
    background:
      radial-gradient(circle at top right, rgba(56, 189, 248, 0.12), transparent 26%),
      radial-gradient(circle at bottom left, rgba(251, 146, 60, 0.12), transparent 24%),
      linear-gradient(180deg, rgba(8, 16, 25, 0.96), rgba(7, 14, 22, 0.94));
    border: 1px solid var(--border);
    box-shadow: var(--shadow-card);
  }

  .journey-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.55), transparent);
    pointer-events: none;
  }

  .journey-intro,
  .journey-grid,
  .journey-outcomes {
    position: relative;
    z-index: 1;
  }

  .journey-intro {
    max-width: 840px;
    margin-bottom: 2.5rem;
  }

  .journey-intro h2 {
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.05em;
    margin-bottom: 1rem;
  }

  .journey-intro p {
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.85;
  }

  .journey-signals {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .journey-signals div {
    padding: 1rem 1.1rem;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .journey-signals span {
    display: block;
    color: var(--primary-light);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.82rem;
    margin-bottom: 0.6rem;
  }

  .journey-signals strong {
    font-size: 0.98rem;
    line-height: 1.45;
  }

  .journey-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .journey-step {
    padding: 1.6rem;
    border-radius: 26px;
  }

  .journey-step-number {
    display: inline-flex;
    margin-bottom: 1rem;
    color: var(--primary-light);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.86rem;
    letter-spacing: 0.08em;
  }

  .journey-step h3 {
    font-size: 1.35rem;
    margin-bottom: 0.85rem;
  }

  .journey-step p,
  .journey-outcome p {
    color: var(--text-muted);
    line-height: 1.75;
  }

  .journey-outcomes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .journey-outcome {
    padding: 1.4rem 1.5rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .journey-outcome h3 {
    margin-bottom: 0.65rem;
    font-size: 1.2rem;
  }

  @media (width < 1024px) {
    .journey-shell {
      padding: 2rem;
    }

    .journey-signals,
    .journey-grid,
    .journey-outcomes {
      grid-template-columns: 1fr;
    }
  }

  @media (width < 768px) {
    .journey-shell {
      padding: 1.25rem;
      border-radius: 26px;
    }

    .journey-intro h2 {
      font-size: 2.1rem;
    }

    .journey-intro p {
      font-size: 1rem;
    }
  }
</style>
