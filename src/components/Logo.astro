---
interface Props {
	showText?: boolean;
	className?: string;
}

const { showText = true, className = "" } = Astro.props;
---

<a href="#" class:list={["logo-container", className]}>
	<svg class="logo-crane" viewBox="0 0 36 43" xmlns="http://www.w3.org/2000/svg">
		<path
			id="head"
			d="M11.7 0.7C12.1 0.3 12.8 0.3 13.2 0.7L17.7 5.2C18.1 5.6 18.1 6.3 17.7 6.7L13.2 11.2C12.8 11.6 12.1 11.6 11.7 11.2L7.2 6.7C6.8 6.3 6.8 5.6 7.2 5.2L11.7 0.7Z"
		></path>
		<path
			id="path3"
			d="M14.8 5.8L18.5 9.5C18.9 9.9 18.9 10.6 18.5 11L9.5 20C9.1 20.4 8.4 20.4 8 20L4.3 16.3C3.9 15.9 3.9 15.2 4.3 14.8L14.8 5.8Z"
		></path>
		<path id="path4" d="M0 22L9 22L9 27L0 27L0 22Z"></path>
		<path
			id="path5"
			d="M9 22L18 22C18.6 22 19 22.4 19 23L19 26C19 26.6 18.6 27 18 27L9 27L9 22Z"
		></path>
		<g id="wing">
			<path
				id="path1"
				d="M23 7C23 5.3 24.3 4 26 4L32 4C33.7 4 35 5.3 35 7L35 15C35 16.7 33.7 18 32 18L26 18C24.3 18 23 16.7 23 15L23 7Z"
			></path>
		</g>
		<path
			d="M9 27L9 35C9 36.7 10.3 38 12 38L27 38C28.7 38 30 39.3 30 41C30 41.6 29.6 42 29 42L12 42C8.1 42 5 38.9 5 35L5 27L9 27Z"
		></path>
	</svg>
	{showText && <span class="logo-text">Accept</span>}
</a>

<style>
	.logo-container {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		transition: transform 0.3s ease;
	}

	.logo-container:hover {
		transform: translateY(-2px);
	}

	.logo-crane {
		width: 36px;
		height: 43px;
		transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
	}

	.logo-container:hover .logo-crane {
		transform: rotate(-10deg) translateY(-3px);
	}

	.logo-crane #head {
		fill: #ffffff;
		animation: headBob 3s ease-in-out infinite;
	}

	.logo-crane #path3 {
		fill: var(--primary);
	}

	.logo-crane #path4 {
		fill: #ffffff;
	}

	.logo-crane #path5 {
		fill: var(--primary-light);
	}

	.logo-crane #path1 {
		fill: #ffffff;
	}

	.logo-crane #wing {
		transform-origin: 31px 11px;
		animation: wingFlap 2s ease-in-out infinite;
	}

	@keyframes wingFlap {
		0%,
		100% {
			transform: rotate(0deg);
		}
		50% {
			transform: rotate(-15deg);
		}
	}

	@keyframes headBob {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-2px);
		}
	}

	.logo-text {
		font-size: 1.5rem;
		font-weight: 800;
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		letter-spacing: -0.5px;
	}
</style>