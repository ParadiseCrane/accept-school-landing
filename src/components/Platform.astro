---
import SectionLabel from "./SectionLabel.astro";

const content = {
  label: "Accept Platform",
  title: "Собственная платформа",
  description:
    "Мы разработали продвинутую платформу для обучения программированию с автоматической проверкой кода и детальным фидбеком",
  features: [
    {
      title: "Мгновенная проверка",
      icon: "⚡",
      description:
        "Отправляйте решения и получайте результаты проверки в режиме реального времени. Детальный фидбек поможет быстрее исправить ошибки.",
    },
    {
      title: "Автоматическое тестирование",
      icon: "🎯",
      description:
        "Ваш код проверяется на множестве тестовых случаев, включая граничные значения и edge cases. Как в настоящих code interviews.",
    },
    {
      title: "Отслеживание прогресса",
      icon: "📊",
      description:
        "Следите за своими достижениями, смотрите статистику решённых задач и анализируйте свой рост как разработчика.",
    },
    {
      title: "Современный интерфейс",
      icon: "💻",
      description:
        "Удобный редактор кода с подсветкой синтаксиса, автодополнением и всеми функциями профессиональной IDE.",
    },
  ],
};
---

<section class="platform section" id="platform">
  <div class="container">
    <div class="section-header">
      <SectionLabel label={content.label} />
      <h2>{content.title}</h2>
      <p>
        {content.description}
      </p>
    </div>
    <div class="platform-showcase">
      {
        content.features.map((e) => {
          return (
            <div class="platform-feature">
              <div class="feature-icon">{e.icon}</div>
              <h4>{e.title}</h4>
              <p>{e.description}</p>
            </div>
          );
        })
      }
    </div>
    <div style="text-align: center; margin-top: 3rem">
      <a
        href="https://code.accept-school.ru/"
        target="_blank"
        class="btn-primary"
      >
        Перейти на платформу
      </a>
    </div>
  </div>
</section>

<style>
  .platform {
    background: var(--bg-dark);
  }

  .platform-showcase {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .platform-feature {
    background: var(--bg-darker);
    padding: 2.5rem;
    border-radius: 20px;
    border: 1px solid var(--border);
    transition: all 0.3s ease;
  }

  .platform-feature:hover {
    border-color: var(--primary);
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
  }

  .feature-icon {
    width: 60px;
    height: 60px;
    background: var(--gradient-1);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }

  .platform-feature h4 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .platform-feature p {
    color: var(--text-muted);
    line-height: 1.7;
  }
</style>
