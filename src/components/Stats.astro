---
const statItems = [
  {
    title: "2",
    description: "Языка обучения: русский и английский",
  },
  {
    title: "100%",
    description: "Практические задания на собственной платформе",
  },
  {
    title: "24/7",
    description: "Доступ к материалам и проверке кода",
  },
];
---

<section class="stats">
  <div class="container">
    <div class="stats-grid">
      {
        statItems.map((e) => {
          return (
            <div class="stat-item">
              <h3>{e.title}</h3>
              <p>{e.description}</p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .stats {
    padding: 5rem 0;
    background: linear-gradient(
      180deg,
      var(--bg-darker) 0%,
      var(--bg-dark) 100%
    );
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
    text-align: center;
  }

  .stat-item h3 {
    font-size: 3.5rem;
    font-weight: 800;
    /* color: var(--primary-light); */
    background: var(--gradient-1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .stat-item p {
    font-size: 1.1rem;
    color: var(--text-muted);
  }
</style>
