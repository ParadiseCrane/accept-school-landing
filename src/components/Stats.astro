---
import { getEntry } from "astro:content";
import type { StatsSectionData } from "../content/sections/stats.schema";

const entry = await getEntry("statsSection", "stats");
if (!entry) throw new Error("Missing sections/stats.md");

const { items: statItems } = entry.data as StatsSectionData;
---

<section class="stats">
  <div class="container">
    <div class="stats-wrapper">
      {
        statItems.map((e) => (
          <div class="stat-item">
            <h3>{e.title}</h3>
            <p>{e.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stats {
    padding: 5rem 0;
    background: linear-gradient(
      180deg,
      var(--bg-darker) 0%,
      var(--bg-dark) 100%
    );
  }

  .stats-wrapper {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
    text-align: center;
  }

  .stat-item h3 {
    font-size: 3.5rem;
    font-weight: 800;
    background: var(--gradient-1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .stat-item p {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  @media (width < 768px) {
    .stat-item h3 {
      font-size: 2.5rem;
    }

    .stat-item p {
      font-size: 1rem;
    }
  }

  @media (width >= 560px) and (width < 1024px) {
    .stats-wrapper {
      grid-template-columns: repeat(2, minmax(250px, 1fr));
    }

    .stats-wrapper > .stat-item:nth-child(3) {
      grid-column: 1 / -1;
      justify-self: center;
      width: min(350px, 100%);
    }
  }
</style>
