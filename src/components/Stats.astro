---
import { getEntry } from "astro:content";
import type { StatsSectionData } from "../content/sections/stats.schema";

const entry = await getEntry("statsSection", "stats");
if (!entry) throw new Error("Missing sections/stats.md");

const { items: statItems } = entry.data as StatsSectionData;
---

<section class="stats section">
  <div class="container">
    <div class="stats-wrapper">
      {
        statItems.map((item, index) => (
          <article class={`stat-item stat-item-${index + 1}`}>
            <span class="stat-label">ключевой сигнал</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stats {
    padding-top: 2rem;
    background: transparent;
  }

  .stat-item {
    border-radius: 30px;
    border: 1px solid var(--border);
    background:
      radial-gradient(circle at top right, rgba(56, 189, 248, 0.08), transparent 26%),
      linear-gradient(180deg, rgba(9, 19, 29, 0.88), rgba(7, 14, 22, 0.86));
    box-shadow: var(--shadow-soft);
  }

  .stats-wrapper {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .stat-item {
    position: relative;
    padding: 1.8rem;
    overflow: hidden;
  }

  .stat-item::after {
    content: "";
    position: absolute;
    inset: auto 12% -16% 12%;
    height: 90px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(125, 249, 230, 0.12), transparent 68%);
    filter: blur(28px);
    pointer-events: none;
  }

  .stat-item-2 {
    background:
      radial-gradient(circle at top right, rgba(251, 146, 60, 0.12), transparent 26%),
      linear-gradient(180deg, rgba(9, 19, 29, 0.88), rgba(7, 14, 22, 0.86));
  }

  .stat-item-3 {
    background:
      radial-gradient(circle at top right, rgba(190, 242, 100, 0.12), transparent 26%),
      linear-gradient(180deg, rgba(9, 19, 29, 0.88), rgba(7, 14, 22, 0.86));
  }

  .stat-label {
    display: inline-flex;
    margin-bottom: 1rem;
    color: var(--primary-light);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .stat-item h3 {
    font-size: clamp(2.6rem, 5vw, 3.8rem);
    font-weight: 800;
    background: var(--gradient-1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.65rem;
    letter-spacing: -0.06em;
  }

  .stat-item p {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.8;
  }

  @media (width < 1024px) {
    .stats-wrapper {
      grid-template-columns: 1fr;
    }

    .stats {
      padding-top: 1rem;
    }
  }

  @media (width < 768px) {
    .stat-item {
      padding: 1.25rem;
      border-radius: 24px;
    }

    .stat-item h3 {
      font-size: 2.8rem;
    }
  }
</style>
