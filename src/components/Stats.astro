---
import { getEntry } from "astro:content";
import type { StatsSectionData } from "../content/sections/stats.schema";

const entry = await getEntry("statsSection", "stats");
if (!entry) throw new Error("Missing sections/stats.md");

const { items: statItems } = entry.data as StatsSectionData;
---

<section class="stats">
  <div class="container">
    <div class="stats-wrapper">
      {
        statItems.map((e) => (
          <div class="stat-item">
            <h3>{e.title}</h3>
            <p>{e.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stats {
    padding: 5rem 0;
    background: transparent;
  }

  .stats-wrapper {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .stat-item {
    text-align: left;
    padding: 2rem;
    border-radius: 24px;
    border: 1px solid rgba(226, 232, 240, 0.08);
    background:
      radial-gradient(circle at top right, rgba(34, 211, 238, 0.08), transparent 35%),
      var(--card-bg);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .stat-item:nth-child(2) {
    background:
      radial-gradient(circle at top right, rgba(249, 115, 22, 0.1), transparent 35%),
      var(--card-bg);
  }

  .stat-item:nth-child(3) {
    background:
      radial-gradient(circle at top right, rgba(132, 204, 22, 0.1), transparent 35%),
      var(--card-bg);
  }

  .stat-item:hover {
    transform: translateY(-6px);
    border-color: rgba(94, 234, 212, 0.24);
    box-shadow:
      0 20px 36px rgba(0, 0, 0, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .stat-item h3 {
    font-size: 3.3rem;
    font-weight: 800;
    background: var(--gradient-1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
    letter-spacing: -0.06em;
  }

  .stat-item p {
    font-size: 1.02rem;
    color: var(--text-muted);
    line-height: 1.75;
  }

  @media (width < 768px) {
    .stat-item h3 {
      font-size: 2.5rem;
    }

    .stat-item p {
      font-size: 1rem;
    }
  }

  @media (width >= 560px) and (width < 1024px) {
    .stats-wrapper {
      grid-template-columns: repeat(2, minmax(250px, 1fr));
    }

    .stats-wrapper > .stat-item:nth-child(3) {
      grid-column: 1 / -1;
      justify-self: center;
      width: min(350px, 100%);
    }
  }
</style>
