---
import SectionLabel from "./SectionLabel.astro";

const paths = [
  {
    number: "01",
    title: "Хочу начать с нуля",
    description: "Спокойный вход в программирование и первая уверенность в коде",
    href: "#courses",
    accent: "rgba(190, 242, 100, 0.16)",
  },
  {
    number: "02",
    title: "Хочу усилить базу",
    description: "Алгоритмы, структуры данных и более сильное мышление",
    href: "#courses",
    accent: "rgba(56, 189, 248, 0.16)",
  },
  {
    number: "03",
    title: "Хочу современный стек",
    description: "Python, API и практика ближе к реальной разработке",
    href: "#courses",
    accent: "rgba(251, 146, 60, 0.16)",
  },
  {
    number: "04",
    title: "Хочу English Track",
    description: "Программирование и английский в одном рабочем ритме",
    href: "#english",
    accent: "rgba(129, 140, 248, 0.16)",
  },
];
---

<section class="section path-chooser">
  <div class="container">
    <div class="path-shell">
      <div class="path-header">
        <SectionLabel label="Быстрый выбор" />
        <h2>Выберите маршрут, который вам ближе</h2>
        <p>Короткий ориентир, чтобы сразу перейти к нужному треку</p>
      </div>

      <div class="path-grid">
        {
          paths.map((path) => (
            <a class="path-card" href={path.href} style={`--path-accent: ${path.accent};`}>
              <span class="path-number">{path.number}</span>
              <h3>{path.title}</h3>
              <p>{path.description}</p>
              <span class="path-link">Открыть маршрут</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .path-chooser {
    padding-top: 2.5rem;
  }

  .path-shell {
    position: relative;
    padding: 2.2rem;
    border-radius: 34px;
    border: 1px solid var(--border);
    background:
      radial-gradient(circle at top right, rgba(56, 189, 248, 0.08), transparent 22%),
      linear-gradient(180deg, rgba(8, 16, 25, 0.96), rgba(7, 14, 22, 0.92));
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .path-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 84px 84px;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.45), transparent);
    pointer-events: none;
  }

  .path-header,
  .path-grid {
    position: relative;
    z-index: 1;
  }

  .path-header {
    max-width: 700px;
    margin-bottom: 1.8rem;
  }

  .path-header h2 {
    font-size: clamp(2.1rem, 4vw, 3.3rem);
    line-height: 1;
    letter-spacing: -0.05em;
    margin-bottom: 0.9rem;
  }

  .path-header p {
    color: var(--text-muted);
    line-height: 1.7;
  }

  .path-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .path-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 1.25rem;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      radial-gradient(circle at top right, var(--path-accent), transparent 34%),
      rgba(255, 255, 255, 0.04);
    color: inherit;
    text-decoration: none;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      background 0.3s ease;
  }

  .path-card:hover {
    transform: translateY(-6px);
    border-color: var(--border-strong);
  }

  .path-number {
    display: inline-flex;
    margin-bottom: 0.9rem;
    color: var(--primary-light);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
  }

  .path-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.65rem;
    line-height: 1.2;
  }

  .path-card p {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
    flex: 1;
  }

  .path-link {
    color: var(--primary-light);
    font-size: 0.92rem;
    font-weight: 700;
  }

  @media (width < 1200px) {
    .path-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width < 768px) {
    .path-chooser {
      padding-top: 1rem;
    }

    .path-shell {
      padding: 1.2rem;
      border-radius: 24px;
    }

    .path-header h2 {
      font-size: 1.9rem;
    }

    .path-grid {
      grid-template-columns: 1fr;
    }

    .path-card {
      padding: 1rem;
    }
  }
</style>
