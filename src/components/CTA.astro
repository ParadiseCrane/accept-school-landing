---
import { getEntry } from "astro:content";
import type { CtaSectionData } from "../content/sections/cta.schema";

const entry = await getEntry("ctaSection", "cta");
if (!entry) throw new Error("Missing sections/cta.md");

const content = entry.data as CtaSectionData;
---

<section class:list={["section", "cta-section"]}>
  <div class="container">
    <div class="cta-shell">
      <div class:list={["section-header", "cta-content"]}>
        <div class="cta-kicker">Старт за несколько сообщений</div>
        <h2>{content.title}</h2>
        <p>{content.description}</p>

        <div class="cta-tags">
          <span>Подбор курса</span>
          <span>Ответы на вопросы</span>
          <span>Удобный темп старта</span>
        </div>

        <a
          href="https://t.me/accept_school_bot"
          target="_blank"
          class="btn-cta-large"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18 1.897-.962 6.502-1.359 8.627-.168.9-.5 1.201-.82 1.23-.697.064-1.226-.461-1.901-.903-1.056-.692-1.653-1.123-2.678-1.799-1.185-.781-.417-1.21.258-1.911.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.139-5.062 3.345-.479.329-.913.489-1.302.481-.428-.009-1.252-.241-1.865-.44-.751-.244-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.831-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635.099-.002.321.023.465.141.121.099.155.232.171.326.016.093.036.305.02.469z"
            ></path>
          </svg>
          Открыть Telegram-бот
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: transparent;
  }

  .cta-shell {
    position: relative;
    overflow: hidden;
    border-radius: 32px;
    padding: 4rem 1.5rem;
    background:
      radial-gradient(circle at top left, rgba(34, 211, 238, 0.18), transparent 28%),
      radial-gradient(circle at bottom right, rgba(249, 115, 22, 0.18), transparent 24%),
      linear-gradient(135deg, rgba(12, 24, 36, 0.96), rgba(9, 18, 29, 0.96));
    border: 1px solid rgba(226, 232, 240, 0.08);
    box-shadow:
      0 28px 70px rgba(0, 0, 0, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .cta-shell::before {
    content: "";
    position: absolute;
    inset: auto 5% -18% auto;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(20, 184, 166, 0.22), transparent 68%);
    filter: blur(18px);
    pointer-events: none;
  }

  .cta-content {
    text-align: center;
    margin-bottom: 0;
    position: relative;
    z-index: 1;
  }

  .cta-content h2 {
    font-weight: 800;
    margin-bottom: 1rem;
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-content p {
    margin-bottom: 2rem;
    color: rgba(248, 251, 255, 0.8);
    margin-left: auto;
    margin-right: auto;
  }

  .cta-kicker {
    width: fit-content;
    margin: 0 auto 1rem;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    background: rgba(20, 184, 166, 0.12);
    border: 1px solid rgba(20, 184, 166, 0.22);
    color: var(--primary-light);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cta-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .cta-tags span {
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    border: 1px solid rgba(226, 232, 240, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: #dbeafe;
    font-size: 0.9rem;
  }

  .btn-cta-large {
    background: var(--gradient-1);
    color: white;
    padding: 1.15rem 2.1rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.1rem;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    box-shadow: 0 18px 40px rgba(20, 184, 166, 0.24);
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }

  .btn-cta-large:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 48px rgba(20, 184, 166, 0.3);
  }

  @media (width < 768px) {
    .cta-shell {
      padding: 3rem 1rem;
    }

    .btn-cta-large {
      padding: 1rem 1.4rem;
      font-size: 1rem;
    }
  }
</style>
