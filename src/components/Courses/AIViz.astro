<script defer>
  function runAiViz() {
    const badge = document.getElementById("aiBadge");
    const inputChip = document.getElementById("aiInputChip");

    if (!badge || !inputChip || badge.dataset.bound === "true") return;

    badge.dataset.bound = "true";

    const wait = (ms) => new Promise((resolve) => window.setTimeout(resolve, ms));
    const groups = {
      input: ["node-i1", "node-i2"],
      hiddenOne: ["node-h1", "node-h2", "node-h3"],
      hiddenTwo: ["node-h4", "node-h5"],
      output: ["node-o1"],
    };

    const resolvedGroups = Object.fromEntries(
      Object.entries(groups).map(([key, ids]) => [
        key,
        ids.map((id) => document.getElementById(id)).filter(Boolean),
      ]),
    );

    const allNodes = Object.values(resolvedGroups).flat();

    const reset = () => {
      inputChip.classList.remove("active");
      allNodes.forEach((node) => node.classList.remove("active", "orange"));
    };

    const activateGroup = async (nodes, delay) => {
      for (const node of nodes) {
        node.classList.add("active");
        await wait(delay);
      }
    };

    const sampleNodes = (nodes, minCount, maxCount) => {
      const shuffled = [...nodes].sort(() => Math.random() - 0.5);
      const count = Math.min(
        nodes.length,
        minCount + Math.floor(Math.random() * (maxCount - minCount + 1)),
      );
      return shuffled.slice(0, count);
    };

    const animate = async () => {
      while (true) {
        reset();
        badge.textContent = "signal ready";

        const inputNodes = sampleNodes(resolvedGroups.input, 1, 2);
        const hiddenOneNodes = sampleNodes(resolvedGroups.hiddenOne, 1, 2);
        const hiddenTwoNodes = sampleNodes(resolvedGroups.hiddenTwo, 1, 1);
        const outputNodes = resolvedGroups.output;
        const outputIsOrange = Math.random() < 0.5;

        inputChip.classList.add("active");
        await wait(700);

        badge.textContent = "input";
        await activateGroup(inputNodes, 380);
        await wait(320);

        badge.textContent = "hidden layer 1";
        await activateGroup(hiddenOneNodes, 420);
        await wait(380);

        badge.textContent = "hidden layer 2";
        await activateGroup(hiddenTwoNodes, 500);
        await wait(420);

        badge.textContent = outputIsOrange ? "output: orange" : "output: green";
        if (outputIsOrange) {
          outputNodes.forEach((node) => node.classList.add("orange"));
        }
        await activateGroup(outputNodes, 650);

        await wait(2200);
      }
    };

    animate();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", runAiViz, { once: true });
  } else {
    runAiViz();
  }
</script>
