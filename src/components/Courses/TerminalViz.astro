<div class="terminal-container">
  <div class="terminal-header">
    <div class="terminal-dot"></div>
    <div class="terminal-dot"></div>
    <div class="terminal-dot"></div>
  </div>
  <div class="terminal-body" id="terminalBody"></div>
</div>

<style>
  .terminal-container {
    background: #1a1a1a;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    width: 100%;
    max-width: 550px;

    .terminal-header {
      background: #2d2d2d;
      padding: 0.75rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      border-bottom: 1px solid #3d3d3d;
    }

    .terminal-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }

    .terminal-dot:nth-child(1) {
      background: #ff5f56;
    }
    .terminal-dot:nth-child(2) {
      background: #ffbd2e;
    }
    .terminal-dot:nth-child(3) {
      background: #27c93f;
    }

    .terminal-body {
      padding: 2rem;
      font-family: "JetBrains Mono", monospace;
      font-size: 1rem;
      line-height: 1.8;
      min-height: 350px;
      color: #e0e0e0;
      transition: opacity 0.3s ease;
    }

    .terminal-line {
      display: inline;
    }

    .terminal-line.prompt {
      color: var(--accent);
      font-weight: 600;
    }

    .terminal-line.command {
      color: var(--primary-light);
    }

    .terminal-line.success {
      color: var(--accent);
    }

    .terminal-line.output {
      color: var(--secondary);
      font-weight: 600;
    }

    .cursor-blink {
      display: inline-block;
      width: 10px;
      height: 20px;
      background: var(--primary-light);
      animation: blink 1s infinite;
      margin-left: 2px;
    }

    @keyframes blink {
      0%,
      49% {
        opacity: 1;
      }
      50%,
      100% {
        opacity: 0;
      }
    }
  }

  @media (width < 768px) {
    .terminal-container .terminal-body {
      padding: 1rem;
    }
  }
</style>

<script defer>
  const terminalSequences = [
    [
      { text: "$ ", class: "prompt", delay: 0 },
      { text: "uv init modern-python", class: "command", delay: 60 },
      { text: "\n", delay: 600 },
      { text: "✓ Initialized project\n\n", class: "success", delay: 40 },
      { text: "\n", delay: 600 },
      { text: "$ ", class: "prompt", delay: 500 },
      { text: "uv add fastapi uvicorn", class: "command", delay: 60 },
      { text: "\n", delay: 600 },
      { text: "✓ Dependencies installed\n\n", class: "success", delay: 40 },
      { text: "\n", delay: 600 },
      { text: "$ ", class: "prompt", delay: 500 },
      { text: "uv run python app.py", class: "command", delay: 60 },
      { text: "\n", delay: 900 },
      {
        text: "⚡ Server running at http://127.0.0.1:8000",
        class: "output",
        delay: 40,
      },
    ],
    [
      { text: "$ ", class: "prompt", delay: 0 },
      { text: "ruff check .", class: "command", delay: 60 },
      { text: "\n", delay: 600 },
      { text: "✓ All checks passed\n\n", class: "success", delay: 40 },
      { text: "\n", delay: 600 },
      { text: "$ ", class: "prompt", delay: 500 },
      { text: "mypy src/", class: "command", delay: 60 },
      { text: "\n", delay: 600 },
      {
        text: "✓ Success: no issues found\n\n",
        class: "success",
        delay: 40,
      },
      { text: "\n", delay: 600 },
      { text: "$ ", class: "prompt", delay: 500 },
      { text: "pytest tests/ -v", class: "command", delay: 60 },
      { text: "\n", delay: 900 },
      { text: "✓ 15 tests passed in 2.3s", class: "output", delay: 40 },
    ],
  ];

  let terminalSeqIndex = 0;

  async function typeTerminal() {
    const body = document.getElementById("terminalBody");
    if (body) {
      body.innerHTML = "";
      const seq = terminalSequences[terminalSeqIndex];

      for (const item of seq) {
        await new Promise((resolve) => setTimeout(resolve, item.delay));

        if (item.text === "\n") {
          body.innerHTML += "<br>";
        } else {
          const span = document.createElement("span");
          span.className = "terminal-line " + item.class;
          body.appendChild(span);

          for (const char of item.text) {
            span.textContent += char;
            await new Promise((resolve) => setTimeout(resolve, item.delay));
          }
        }
      }

      const cursor = document.createElement("span");
      cursor.className = "cursor-blink";
      body.appendChild(cursor);

      await new Promise((resolve) => setTimeout(resolve, 3000));
      body.style.opacity = "0";
      await new Promise((resolve) => setTimeout(resolve, 500));
      body.style.opacity = "1";

      terminalSeqIndex = (terminalSeqIndex + 1) % terminalSequences.length;
      setTimeout(typeTerminal, 500);
    }
  }

  // Initialize animations
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", typeTerminal);
  } else {
    typeTerminal();
  }
</script>
