<div class="terminal-container">
  <div class="terminal-header">
    <div class="terminal-dot"></div>
    <div class="terminal-dot"></div>
    <div class="terminal-dot"></div>
    <div class="terminal-title">modern-python.sh</div>
    <div class="terminal-badge">live workflow</div>
  </div>

  <div class="terminal-body" id="terminalBody"></div>

  <div class="terminal-footer">
    <span>uv</span>
    <span>ruff</span>
    <span>ty</span>
    <span>FastAPI</span>
    <span>pytest</span>
  </div>
</div>

<style>
  .terminal-container {
    background: #0f1720;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, 0.12);
    box-shadow: 0 16px 44px rgba(0, 0, 0, 0.5);
    width: 100%;
    max-width: 550px;
  }

  .terminal-header {
    background: #202938;
    padding: 0.85rem 1rem;
    display: grid;
    grid-template-columns: repeat(3, auto) minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .terminal-dot:nth-child(1) {
    background: #ff5f56;
  }

  .terminal-dot:nth-child(2) {
    background: #ffbd2e;
  }

  .terminal-dot:nth-child(3) {
    background: #27c93f;
  }

  .terminal-title {
    font-family: "JetBrains Mono", monospace;
    color: #cbd5e1;
    font-size: 0.95rem;
    margin-left: 0.5rem;
  }

  .terminal-badge {
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background: rgba(14, 165, 233, 0.14);
    color: #7dd3fc;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .terminal-body {
    padding: 1.4rem 1.25rem;
    height: 320px;
    overflow: hidden;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.94rem;
    line-height: 1.8;
    color: #e2e8f0;
    transition: opacity 0.35s ease;
    background:
      radial-gradient(circle at top right, rgba(34, 211, 238, 0.08), transparent 30%),
      linear-gradient(180deg, rgba(10, 15, 29, 0.98), rgba(4, 7, 18, 0.98));
  }

  .terminal-container :global(.terminal-row) {
    display: block;
    min-height: 1.8em;
    white-space: pre-wrap;
    padding: 0.26rem 0;
  }

  .terminal-container :global(.terminal-line.prompt) {
    color: #6ee7b7;
    font-weight: 700;
  }

  .terminal-container :global(.terminal-line.command) {
    color: #f8fafc;
  }

  .terminal-container :global(.terminal-line.tool) {
    color: #fbbf24;
    font-weight: 700;
  }

  .terminal-container :global(.terminal-line.subcommand) {
    color: #f8fafc;
  }

  .terminal-container :global(.terminal-line.package) {
    color: #c4b5fd;
  }

  .terminal-container :global(.terminal-line.path) {
    color: #67e8f9;
  }

  .terminal-container :global(.terminal-line.url) {
    color: #93c5fd;
  }

  .terminal-container :global(.terminal-line.number) {
    color: #fdba74;
  }

  .terminal-container :global(.terminal-line.label) {
    color: #f9a8d4;
  }

  .terminal-container :global(.terminal-line.output) {
    color: #93c5fd;
  }

  .terminal-container :global(.terminal-line.success) {
    color: #5eead4;
  }

  .terminal-container :global(.terminal-line.dim) {
    color: #94a3b8;
  }

  .terminal-container :global(.cursor-blink) {
    display: inline-block;
    width: 0.62ch;
    height: 1.15em;
    margin-left: 0.14rem;
    vertical-align: -0.16em;
    border-radius: 2px;
    background: #5eead4;
    animation: blink 1s step-end infinite;
  }

  .terminal-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 1rem 1.25rem 1.25rem;
    background: linear-gradient(180deg, rgba(26, 26, 26, 0), rgba(20, 20, 20, 0.9));
  }

  .terminal-footer span {
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.12);
    background: rgba(30, 41, 59, 0.72);
    color: #cbd5e1;
    font-size: 0.85rem;
  }

  @keyframes blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  @media (width < 768px) {
    .terminal-body {
      padding: 1rem;
      height: 280px;
      font-size: 0.86rem;
    }

    .terminal-header {
      grid-template-columns: repeat(3, auto) minmax(0, 1fr);
    }

    .terminal-badge {
      display: none;
    }
  }
</style>

<script defer>
  const terminalSequences = [
    [
      {
        rowClass: "is-command",
        parts: [
          ["prompt", "$ "],
          ["tool", "uv"],
          ["command", " "],
          ["subcommand", "init"],
          ["command", " "],
          ["path", "modern-python"],
        ],
        pauseAfter: 380,
      },
      {
        rowClass: "is-success",
        parts: [
          ["success", "Initialized project with "],
          ["path", "pyproject.toml"],
        ],
        pauseAfter: 260,
      },
      {
        rowClass: "is-command",
        parts: [
          ["prompt", "$ "],
          ["tool", "uv"],
          ["command", " "],
          ["subcommand", "add"],
          ["command", " "],
          ["package", "fastapi"],
          ["command", " "],
          ["package", "ruff"],
          ["command", " "],
          ["package", "ty"],
          ["command", " "],
          ["package", "pytest"],
        ],
        pauseAfter: 440,
      },
      {
        rowClass: "is-output",
        parts: [
          ["output", "Resolved "],
          ["number", "18"],
          ["output", " packages in "],
          ["number", "142ms"],
        ],
        pauseAfter: 220,
      },
      {
        rowClass: "is-success",
        parts: [
          ["success", "Installed "],
          ["package", "fastapi"],
          ["success", ", "],
          ["package", "ruff"],
          ["success", ", "],
          ["package", "ty"],
          ["success", ", "],
          ["package", "pytest"],
        ],
        pauseAfter: 1100,
      },
    ],
    [
      {
        rowClass: "is-command",
        parts: [
          ["prompt", "$ "],
          ["tool", "uv"],
          ["command", " "],
          ["subcommand", "run"],
          ["command", " "],
          ["package", "ruff"],
          ["command", " check ."],
        ],
        pauseAfter: 360,
      },
      {
        rowClass: "is-success",
        parts: [["success", "All checks passed"]],
        pauseAfter: 220,
      },
      {
        rowClass: "is-command",
        parts: [
          ["prompt", "$ "],
          ["tool", "uv"],
          ["command", " "],
          ["subcommand", "run"],
          ["command", " "],
          ["package", "ty"],
          ["command", " check "],
          ["path", "src/"],
        ],
        pauseAfter: 360,
      },
      {
        rowClass: "is-success",
        parts: [
          ["success", "Checked "],
          ["number", "12"],
          ["success", " files, "],
          ["number", "0"],
          ["success", " errors"],
        ],
        pauseAfter: 220,
      },
      {
        rowClass: "is-command",
        parts: [
          ["prompt", "$ "],
          ["tool", "uv"],
          ["command", " "],
          ["subcommand", "run"],
          ["command", " "],
          ["package", "pytest"],
          ["command", " "],
          ["path", "tests/"],
          ["command", " -q"],
        ],
        pauseAfter: 400,
      },
      {
        rowClass: "is-output",
        parts: [
          ["number", "8"],
          ["output", " passed in "],
          ["number", "1.21s"],
        ],
        pauseAfter: 1100,
      },
    ],
    [
      {
        rowClass: "is-command",
        parts: [
          ["prompt", "$ "],
          ["tool", "uv"],
          ["command", " "],
          ["subcommand", "run"],
          ["command", " "],
          ["package", "fastapi"],
          ["command", " dev "],
          ["path", "src/app.py"],
        ],
        pauseAfter: 420,
      },
      {
        rowClass: "is-dim",
        parts: [
          ["label", "INFO"],
          ["dim", "    Watching for changes in "],
          ["path", "/src"],
        ],
        pauseAfter: 180,
      },
      {
        rowClass: "is-success",
        parts: [
          ["label", "INFO"],
          ["success", "    Uvicorn running on "],
          ["url", "http://127.0.0.1:8000"],
        ],
        pauseAfter: 280,
      },
      {
        rowClass: "is-output",
        parts: [
          ["label", "GET"],
          ["output", "     "],
          ["path", "/health"],
          ["output", '   -> {"status":"ok"}'],
        ],
        pauseAfter: 180,
      },
      {
        rowClass: "is-output",
        parts: [
          ["label", "GET"],
          ["output", "     "],
          ["path", "/docs"],
          ["output", "     -> "],
          ["number", "200"],
          ["success", " OK"],
        ],
        pauseAfter: 1200,
      },
    ],
  ];

  let terminalSeqIndex = 0;

  const wait = (ms) => new Promise((resolve) => window.setTimeout(resolve, ms));

  async function typeLine(body, parts, charDelay, rowClass) {
    const row = document.createElement("div");
    row.className = `terminal-row ${rowClass || ""}`.trim();
    body.appendChild(row);

    for (const [tokenClass, text] of parts) {
      const span = document.createElement("span");
      span.className = `terminal-line ${tokenClass}`;
      row.appendChild(span);

      for (const char of text) {
        span.textContent += char;
        await wait(charDelay);
      }
    }

    return row;
  }

  function mountCursor(target) {
    const cursor = document.createElement("span");
    cursor.className = "cursor-blink";
    target.appendChild(cursor);
    return cursor;
  }

  async function typeTerminal() {
    const body = document.getElementById("terminalBody");

    if (!body || body.dataset.bound === "true") return;

    body.dataset.bound = "true";

    while (true) {
      body.innerHTML = "";
      const sequence = terminalSequences[terminalSeqIndex];
      const cursorHost = document.createElement("div");
      cursorHost.className = "terminal-row";
      body.appendChild(cursorHost);
      let cursor = mountCursor(cursorHost);

      for (const step of sequence) {
        cursor.remove();
        const row = await typeLine(body, step.parts, 28, step.rowClass);
        cursor = mountCursor(row);
        await wait(step.pauseAfter);
      }

      await wait(1300);
      body.style.opacity = "0";
      await wait(320);
      body.style.opacity = "1";

      terminalSeqIndex = (terminalSeqIndex + 1) % terminalSequences.length;
      await wait(220);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", typeTerminal, { once: true });
  } else {
    typeTerminal();
  }
</script>
