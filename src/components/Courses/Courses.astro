---
import SectionLabel from "../SectionLabel.astro";
import SortViz from "./SortViz.astro";
import TerminalViz from "./TerminalViz.astro";

const content = {
  label: "Наши курсы",
  title: "Программы обучения",
  description:
    "Два ключевых курса для формирования фундаментальных навыков программирования и современной разработки",
  courses: [
    {
      type: "algorithms",
      title: "Алгоритмы и структуры данных",
      description:
        "Фундаментальный курс для понимания основ computer science. Изучите алгоритмы сортировки, поиска, работу с графами, деревьями и другими структурами данных.",
      items: [
        "Анализ сложности алгоритмов (Big O)",
        "Классические алгоритмы сортировки и поиска",
        "Работа с деревьями, графами и хеш-таблицами",
        "Динамическое программирование",
        "Практические задачи с автопроверкой",
      ],
      element: SortViz,
    },
    {
      type: "python",
      title: "Modern Python",
      description:
        "Изучите современный Python с использованием актуальных инструментов: uv, ruff, mypy. Освойте профессиональную разработку и лучшие практики индустрии.",
      items: [
        "Современные инструменты разработки (uv, ruff)",
        "Type hints и статическая типизация (mypy)",
        "FastAPI и асинхронное программирование",
        "Работа с базами данных и API",
        "Реальные проекты и code review",
      ],
      element: TerminalViz,
    },
  ],
};
---

<section id="courses" class="section">
  <div class="container">
    <div class="section-header">
      <SectionLabel label={content.label} />
      <h2>{content.title}</h2>
      <p>
        {content.description}
      </p>
    </div>

    {
      content.courses.map((e) => {
        return (
          <div class={`course-card ${e.type}`}>
            <div class="course-content">
              <e.element />
              <div class="section-header-secondary">
                <h3>{e.title}</h3>
                <p>{e.description}</p>
                <ul class="course-features">
                  {e.items.map((li) => {
                    return <li>{li}</li>;
                  })}
                </ul>
                <a
                  href="https://t.me/accept_school_bot"
                  target="_blank"
                  class="btn-primary"
                >
                  Записаться на курс
                </a>
              </div>
            </div>
          </div>
        );
      })
    }
  </div>
</section>

<style>
  #courses {
    background: var(--bg-dark);
  }

  .course-card {
    background: var(--bg-darker);
    border-radius: 24px;
    padding: 3rem;
    border: 1px solid var(--border);
    margin-bottom: 3rem;
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
  }

  .course-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--gradient-1);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .course-card:hover::before {
    transform: scaleX(1);
  }

  .course-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
    border-color: var(--primary);
  }

  .course-card.algorithms::before {
    background: var(--gradient-1);
  }

  .course-card.python::before {
    background: var(--gradient-2);
  }

  .course-content {
    display: grid;
    /* grid-template-columns: 1fr 1fr; */
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: center;
  }

  .course-content > * {
    min-width: 0;
  }

  .course-features {
    list-style: none;
    margin-bottom: 2rem;
  }

  .course-features li {
    padding: 0.75rem 0;
    padding-left: 2rem;
    position: relative;
    color: var(--text-muted);
    font-size: 1rem;
  }

  .course-features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: bold;
    font-size: 1.2rem;
  }

  .python {
    margin-bottom: 0;
  }

  @media (width < 768px) {
    .course-card {
      padding: 1rem;
    }

    .course-features li {
      padding: 0.25rem 0;
      padding-left: 2rem;
    }
  }

  @media (width < 1024px) {
    .course-content {
      display: flex;
      flex-direction: column;
    }

    .course-content .btn-primary {
      display: block;
      margin: 0 auto;
      width: 100%;
      max-width: 400px;
      text-align: center;
    }
  }
</style>
