---
// Terminal animation component
---

<div class="terminal-window">
	<div class="terminal-header">
		<div class="dots">
			<span></span>
			<span></span>
			<span></span>
		</div>
		<span class="terminal-title">terminal</span>
	</div>
	<div class="terminal-body" id="terminalBody"></div>
</div>

<style>
	.terminal-window {
		background: #1a1a1a;
		border: 1px solid var(--border);
		border-radius: 12px;
		overflow: hidden;
		min-height: 250px;
	}

	.terminal-header {
		background: #2a2a2a;
		padding: 0.75rem 1rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		border-bottom: 1px solid var(--border);
	}

	.dots {
		display: flex;
		gap: 0.5rem;
	}

	.dots span {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: var(--text-muted);
	}

	.dots span:nth-child(1) {
		background: #ef4444;
	}

	.dots span:nth-child(2) {
		background: #f59e0b;
	}

	.dots span:nth-child(3) {
		background: #10b981;
	}

	.terminal-title {
		color: var(--text-muted);
		font-size: 0.85rem;
	}

	.terminal-body {
		padding: 1.5rem;
		font-family: "JetBrains Mono", monospace;
		font-size: 0.9rem;
		min-height: 200px;
		transition: opacity 0.3s ease;
	}

	:global(.terminal-line) {
		display: inline;
	}

	:global(.terminal-line.prompt) {
		color: #10b981;
	}

	:global(.terminal-line.command) {
		color: #60a5fa;
	}

	:global(.terminal-line.success) {
		color: #10b981;
	}

	:global(.terminal-line.output) {
		color: var(--text-muted);
	}

	:global(.cursor-blink) {
		display: inline-block;
		width: 8px;
		height: 16px;
		background: var(--primary-light);
		animation: blink 1s infinite;
	}

	@keyframes blink {
		0%,
		50% {
			opacity: 1;
		}
		51%,
		100% {
			opacity: 0;
		}
	}
</style>

<script>
	type TerminalItem = {
		text: string;
		class: string;
		delay: number;
	};

	const terminalSequences: TerminalItem[][] = [
		[
			{ text: "$ ", class: "prompt", delay: 0 },
			{ text: "uv init modern-python", class: "command", delay: 60 },
			{ text: "\n", class: "", delay: 600 },
			{ text: "✓ Initialized project\n\n", class: "success", delay: 40 },
			{ text: "$ ", class: "prompt", delay: 500 },
			{ text: "uv add fastapi uvicorn", class: "command", delay: 60 },
			{ text: "\n", class: "", delay: 600 },
			{ text: "✓ Dependencies installed\n\n", class: "success", delay: 40 },
			{ text: "$ ", class: "prompt", delay: 500 },
			{ text: "uv run python app.py", class: "command", delay: 60 },
			{ text: "\n", class: "", delay: 900 },
			{ text: "⚡ Server running at http://127.0.0.1:8000", class: "output", delay: 40 },
		],
		[
			{ text: "$ ", class: "prompt", delay: 0 },
			{ text: "ruff check .", class: "command", delay: 60 },
			{ text: "\n", class: "", delay: 600 },
			{ text: "✓ All checks passed\n\n", class: "success", delay: 40 },
			{ text: "$ ", class: "prompt", delay: 500 },
			{ text: "mypy src/", class: "command", delay: 60 },
			{ text: "\n", class: "", delay: 600 },
			{ text: "✓ Success: no issues found\n\n", class: "success", delay: 40 },
			{ text: "$ ", class: "prompt", delay: 500 },
			{ text: "pytest tests/ -v", class: "command", delay: 60 },
			{ text: "\n", class: "", delay: 900 },
			{ text: "✓ 15 tests passed in 2.3s", class: "output", delay: 40 },
		],
	];

	let terminalSeqIndex = 0;

	async function typeTerminal() {
		const body = document.getElementById("terminalBody");
		if (!body) return;

		body.innerHTML = "";
		const seq = terminalSequences[terminalSeqIndex];

		for (const item of seq) {
			await new Promise((resolve) => setTimeout(resolve, item.delay));

			if (item.text === "\n") {
				body.innerHTML += "<br>";
			} else {
				const span = document.createElement("span");
				span.className = "terminal-line " + item.class;
				body.appendChild(span);

				for (const char of item.text) {
					span.textContent += char;
					await new Promise((resolve) => setTimeout(resolve, item.delay));
				}
			}
		}

		const cursor = document.createElement("span");
		cursor.className = "cursor-blink";
		body.appendChild(cursor);

		await new Promise((resolve) => setTimeout(resolve, 3000));
		body.style.opacity = "0";
		await new Promise((resolve) => setTimeout(resolve, 500));
		body.style.opacity = "1";

		terminalSeqIndex = (terminalSeqIndex + 1) % terminalSequences.length;
		setTimeout(typeTerminal, 500);
	}

	// Start animation when DOM is ready
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", typeTerminal);
	} else {
		typeTerminal();
	}
</script>