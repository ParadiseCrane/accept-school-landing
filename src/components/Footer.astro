---
import Logo from "./Logo.astro";

const footerSections = [
	{
		title: "Курсы",
		links: [
			{ label: "Modern Python", href: "#" },
			{ label: "Web Development", href: "#" },
			{ label: "Computer Science", href: "#" },
		],
	},
	{
		title: "Компания",
		links: [
			{ label: "О нас", href: "#" },
			{ label: "Менторы", href: "#" },
			{ label: "Блог", href: "#" },
			{ label: "Карьера", href: "#" },
		],
	},
	{
		title: "Контакты",
		links: [
			{ label: "Email: hello@accept.school", href: "#" },
			{ label: "Telegram: @acceptschool", href: "#" },
			{ label: "Discord", href: "#" },
		],
	},
];
---

<footer class="footer">
	<div class="container">
		<div class="footer-content">
			<div class="footer-section">
				<div class="footer-logo-wrapper">
					<Logo />
				</div>
				<p class="footer-description">Онлайн-школа программирования нового поколения</p>
			</div>

			{
				footerSections.map((section) => (
					<div class="footer-section">
						<h4>{section.title}</h4>
						<ul class="footer-links">
							{section.links.map((link) => (
								<li>
									<a href={link.href}>{link.label}</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>

		<div class="footer-bottom">
			<p>&copy; 2024 Accept School. Все права защищены.</p>
			<div class="footer-legal">
				<a href="#">Политика конфиденциальности</a>
				<a href="#">Условия использования</a>
			</div>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: var(--bg-dark);
		padding: 4rem 0 2rem;
		border-top: 1px solid var(--border);
	}

	.footer-content {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr 1fr;
		gap: 3rem;
		margin-bottom: 3rem;
	}

	.footer-logo-wrapper {
		margin-bottom: 1rem;
	}

	.footer-description {
		color: var(--text-muted);
		line-height: 1.7;
	}

	.footer-section h4 {
		font-size: 1.1rem;
		margin-bottom: 1rem;
		font-weight: 600;
	}

	.footer-links {
		list-style: none;
	}

	.footer-links li {
		margin-bottom: 0.75rem;
	}

	.footer-links a {
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.3s ease;
	}

	.footer-links a:hover {
		color: var(--primary-light);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.footer-bottom p {
		color: var(--text-muted);
	}

	.footer-legal {
		display: flex;
		gap: 2rem;
	}

	.footer-legal a {
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.9rem;
	}

	.footer-legal a:hover {
		color: var(--primary-light);
	}

	@media (max-width: 1024px) {
		.footer-content {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 768px) {
		.footer-content {
			grid-template-columns: 1fr;
		}

		.footer-bottom {
			flex-direction: column;
			gap: 1rem;
			text-align: center;
		}

		.footer-legal {
			flex-direction: column;
			gap: 0.5rem;
		}
	}
</style>