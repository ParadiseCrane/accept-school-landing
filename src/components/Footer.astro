---
import Logo from "./Logo.astro";

import { getEntry } from "astro:content";
import type { FooterSectionData } from "../content/sections/footer.schema";

const entry = await getEntry("footerSection", "footer");
if (!entry) throw new Error("Missing sections/footer.md");

const content = entry.data as FooterSectionData;
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand surface-card">
        <div class="footer-logo-wrapper">
          <Logo hideLogo />
        </div>

        <p class="footer-description">{content.description}</p>

        <div class="footer-cta-row">
          <a href={content.social.telegram.href} target="_blank" class="btn-secondary">
            Написать в Telegram
          </a>

          <div class="social-links">
            <a
              href={content.social.telegram.href}
              target="_blank"
              title={content.social.telegram.title}
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18 1.897-.962 6.502-1.359 8.627-.168.9-.5 1.201-.82 1.23-.697.064-1.226-.461-1.901-.903-1.056-.692-1.653-1.123-2.678-1.799-1.185-.781-.417-1.21.258-1.911.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.139-5.062 3.345-.479.329-.913.489-1.302.481-.428-.009-1.252-.241-1.865-.44-.751-.244-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.831-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635.099-.002.321.023.465.141.121.099.155.232.171.326.016.093.036.305.02.469z"
                ></path>
              </svg>
            </a>

            <a
              href={content.social.github.href}
              target="_blank"
              title={content.social.github.title}
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
                ></path>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <div class="footer-links-grid">
        {
          content.sections.map((section) => (
            <div class="footer-section">
              <h4>{section.title}</h4>
              <ul class="footer-links">
                {section.links.map((link) => (
                  <li>
                    <a href={link.href}>{link.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {content.rights}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(180deg, rgba(5, 11, 18, 0.4), rgba(5, 11, 18, 0.92));
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--border);
  }

  .footer-top {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .footer-brand {
    padding: 1.6rem;
    border-radius: 30px;
  }

  .footer-logo-wrapper {
    margin-bottom: 1rem;
  }

  .footer-description {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1.5rem;
    max-width: 52ch;
  }

  .footer-cta-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-links-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .footer-section {
    padding: 1.4rem;
    border-radius: 24px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.03);
  }

  .footer-section h4 {
    font-size: 1rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .footer-links {
    list-style: none;
  }

  .footer-links li + li {
    margin-top: 0.7rem;
  }

  .footer-links a {
    color: var(--text-muted);
    text-decoration: none;
    line-height: 1.6;
    transition: color 0.25s ease;
  }

  .footer-links a:hover {
    color: var(--primary-light);
  }

  .footer-bottom {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .footer-bottom p {
    color: var(--text-muted);
  }

  .social-links {
    display: flex;
    gap: 0.8rem;
  }

  .social-links a {
    width: 42px;
    height: 42px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary-light);
    transition: all 0.3s ease;
  }

  .social-links a:hover {
    background: rgba(20, 184, 166, 0.14);
    border-color: rgba(125, 249, 230, 0.22);
    transform: translateY(-3px);
  }

  @media (width < 1024px) {
    .footer-top,
    .footer-links-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (width < 768px) {
    .footer-brand,
    .footer-section {
      padding: 1rem;
      border-radius: 22px;
    }

    .footer-cta-row {
      align-items: stretch;
    }

    .footer-cta-row .btn-secondary {
      width: 100%;
    }
  }
</style>
