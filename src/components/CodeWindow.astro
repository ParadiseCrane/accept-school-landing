---
interface Props {
	title?: string;
	rotating?: boolean;
}

const { title = "modern_python.py", rotating = false } = Astro.props;
---

<div class="code-window">
	<div class="code-header">
		<div class="dots">
			<span></span>
			<span></span>
			<span></span>
		</div>
		<span class="code-title">{title}</span>
    <span class="code-badge">demo</span>
	</div>
	<div class="code-body">
		<pre><code id={rotating ? "rotatingCode" : undefined}><slot>const greeting = "Hello, World!";</slot></code></pre>
	</div>
</div>

<style>
	.code-window {
		background: linear-gradient(180deg, rgba(8, 16, 26, 0.98), rgba(10, 19, 30, 0.92));
		border: 1px solid rgba(226, 232, 240, 0.1);
		border-radius: 24px;
		overflow: hidden;
		box-shadow: 0 28px 70px rgba(0, 0, 0, 0.38);
	}

	.code-header {
		background: rgba(255, 255, 255, 0.03);
		padding: 1rem 1.5rem;
		display: flex;
		align-items: center;
		gap: 1rem;
		border-bottom: 1px solid rgba(226, 232, 240, 0.08);
	}

	.dots {
		display: flex;
		gap: 0.5rem;
	}

	.dots span {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: var(--text-muted);
	}

	.dots span:nth-child(1) {
		background: #ef4444;
	}

	.dots span:nth-child(2) {
		background: #f59e0b;
	}

	.dots span:nth-child(3) {
		background: #10b981;
	}

	.code-title {
		color: var(--text-muted);
		font-size: 0.9rem;
    font-family: "JetBrains Mono", monospace;
    margin-right: auto;
	}

  .code-badge {
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(94, 234, 212, 0.22);
    background: rgba(20, 184, 166, 0.12);
    color: var(--primary-light);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

	.code-body {
		background:
      radial-gradient(circle at top right, rgba(34, 211, 238, 0.12), transparent 28%),
      rgba(9, 18, 29, 0.92);
		padding: 2.4rem 2rem;
		font-family: "JetBrains Mono", monospace;
	}

	.code-body pre {
		margin: 0;
		min-height: 60px;
	}

	.code-body code {
		font-family: "JetBrains Mono", monospace;
		font-size: 1.35rem;
		font-weight: 600;
		text-wrap: initial;
		color: #dffef8;
		transition: opacity 0.3s ease;
    text-shadow: 0 0 24px rgba(94, 234, 212, 0.16);
	}

  @media (width < 768px) {
		.code-body code {
			font-size: 1rem;
		}
	}
</style>

{
	rotating && (
		<script>
			const codeTexts = [
				"while learning: level_up()",
				"def success(): return practice",
				"import knowledge from accept",
				"class Student(Genius): pass",
				"for skill in skills: master(skill)",
			];
			let codeIndex = 0;
			const rotatingCode = document.getElementById("rotatingCode");

			if (rotatingCode) {
				setInterval(() => {
					rotatingCode.style.opacity = "0";
					setTimeout(() => {
						codeIndex = (codeIndex + 1) % codeTexts.length;
						rotatingCode.textContent = codeTexts[codeIndex];
						rotatingCode.style.opacity = "1";
					}, 300);
				}, 3500);
			}
		</script>
	)
}
