---
import TestimonialCard from "./TestimonialCard.astro";

const testimonials = [
	{
		quote:
			"Accept School — это лучшая инвестиция в моё образование. Живые менторы, современные инструменты, реальные проекты. Через 6 месяцев я получил оффер в топовую компанию.",
		name: "Алексей Кузнецов",
		role: "Python Developer @ Яндекс",
		avatar: "АК",
	},
	{
		quote:
			"Наконец-то нашла курс, где учат современному Python, а не Python 2.7 из 2010 года. Type hints, async/await, современные инструменты — всё как в реальной разработке.",
		name: "Мария Соколова",
		role: "Backend Developer @ VK",
		avatar: "МС",
	},
	{
		quote:
			"Курс по CS дал мне то глубокое понимание, которого не хватало после самообучения. Алгоритмы, структуры данных, системы — теперь я понимаю, как всё работает под капотом.",
		name: "Дмитрий Петров",
		role: "Full Stack @ Тинькофф",
		avatar: "ДП",
	},
];
---

<section id="testimonials" class="section testimonials-section">
	<div class="container">
		<div class="section-header">
			<h2>Отзывы студентов</h2>
			<p>Что говорят наши выпускники</p>
		</div>

		<div class="testimonials-grid">
			{testimonials.map((testimonial) => <TestimonialCard {...testimonial} />)}
		</div>
	</div>
</section>

<style>
	.testimonials-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 2rem;
	}

	@media (max-width: 768px) {
		.testimonials-grid {
			grid-template-columns: 1fr;
		}
	}
</style>