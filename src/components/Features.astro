---
import FeatureCard from "./FeatureCard.astro";

const features = [
	{
		icon: "👨‍🏫",
		title: "Живые менторы",
		description: "Код-ревью от практикующих разработчиков. Обратная связь по каждому проекту.",
	},
	{
		icon: "🚀",
		title: "Современные инструменты",
		description: "uv, ruff, mypy для Python. Vite, TypeScript для веба. Актуальный стек 2024.",
	},
	{
		icon: "💼",
		title: "Реальные проекты",
		description: "Пишите код как в production. CI/CD, тесты, документация, деплой.",
	},
	{
		icon: "🎯",
		title: "Практика > Теория",
		description: "80% времени — кодинг. Не просто смотрите, а создаёте.",
	},
	{
		icon: "🧠",
		title: "Глубокое понимание",
		description: "Не зубрёжка, а понимание как всё работает. От основ до архитектуры.",
	},
	{
		icon: "⚡",
		title: "Быстрый старт",
		description: "Первый код в первый день. Быстрая обратная связь и результаты.",
	},
];
---

<section id="features" class="section features-section">
	<div class="container">
		<div class="section-header">
			<h2>Почему Accept School?</h2>
			<p>Современный подход к обучению программированию</p>
		</div>

		<div class="features-grid">
			{features.map((feature) => <FeatureCard {...feature} />)}
		</div>
	</div>
</section>

<style>
	.features-section {
		background: var(--bg-dark);
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	@media (max-width: 768px) {
		.features-grid {
			grid-template-columns: 1fr;
		}
	}
</style>