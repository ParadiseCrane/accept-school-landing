---
import MatrixBackground from "./MatrixBackground.astro";
import CodeWindow from "./CodeWindow.astro";

import { getEntry } from "astro:content";
import type { HeroSectionData } from "../content/sections/hero.schema";

const entry = await getEntry("heroSection", "hero");
if (!entry) throw new Error("Missing sections/hero.md");

const content = entry.data as HeroSectionData;

const heroHighlights = [
  "Живая практика",
  "Своя платформа",
  "Русский или английский трек",
];

const heroSignals = [
  { value: "4", label: "направления роста" },
  { value: "RU / EN", label: "два языка обучения" },
  { value: "24/7", label: "доступ к платформе" },
];
---

<section class="hero">
  <MatrixBackground />

  <div class="container hero-container">
    <div class="hero-content">
      <div class="hero-copy">
        <div class="hero-panel">
          <div class="hero-kicker">
            <span class="hero-kicker-pill">Набор открыт</span>
          </div>

          <div class="hero-badges">
            <span>4 курса</span>
            <span>Accept Platform</span>
            <span>English Track</span>
          </div>

          <h1 class="hero-title">
            <span>{content.title} </span>
            <span class="gradient-text">{content.titleColored}</span>
          </h1>

          <p class="hero-description">{content.description}</p>

          <div class="hero-buttons">
            <a href="https://t.me/accept_school_bot" class="btn-primary">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18 1.897-.962 6.502-1.359 8.627-.168.9-.5 1.201-.82 1.23-.697.064-1.226-.461-1.901-.903-1.056-.692-1.653-1.123-2.678-1.799-1.185-.781-.417-1.21.258-1.911.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.139-5.062 3.345-.479.329-.913.489-1.302.481-.428-.009-1.252-.241-1.865-.44-.751-.244-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.831-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635.099-.002.321.023.465.141.121.099.155.232.171.326.016.093.036.305.02.469z"
                ></path>
              </svg>
              Начать обучение
            </a>

            <a href="#courses" class="btn-secondary">Смотреть программы</a>
          </div>

          <div class="hero-highlights">
            {
              heroHighlights.map((item) => (
                <div class="hero-highlight-chip">
                  <span></span>
                  <p>{item}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-visual-shell">
          <CodeWindow rotating={true}>while learning: level_up()</CodeWindow>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 6rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 32%, rgba(34, 211, 238, 0.11), transparent 28%),
      radial-gradient(circle at 82% 18%, rgba(251, 146, 60, 0.1), transparent 24%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-container {
    position: relative;
    z-index: 2;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .hero-content {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.7fr);
    gap: 3.5rem;
    align-items: center;
  }

  .hero-panel {
    position: relative;
    padding: 2.5rem;
    border-radius: 32px;
    background:
      linear-gradient(180deg, rgba(9, 19, 29, 0.74), rgba(6, 14, 22, 0.62));
    border: 1px solid rgba(226, 232, 240, 0.08);
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(18px);
  }

  .hero-panel::after {
    content: "";
    position: absolute;
    inset: 1rem auto auto 1rem;
    width: 180px;
    height: 180px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(20, 184, 166, 0.12), transparent 72%);
    filter: blur(24px);
    pointer-events: none;
  }

  .hero-kicker {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.25rem;
  }

  .hero-kicker-pill {
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    background: rgba(125, 249, 230, 0.12);
    border: 1px solid rgba(125, 249, 230, 0.22);
    color: var(--primary-light);
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-kicker-text {
    color: var(--text-soft);
    font-size: 0.95rem;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.35rem;
  }

  .hero-badges span {
    padding: 0.6rem 0.95rem;
    border-radius: 999px;
    border: 1px solid rgba(226, 232, 240, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: #dbeafe;
    font-size: 0.86rem;
    font-weight: 600;
  }

  .hero-title {
    font-size: clamp(2.1rem, 4.34vw, 3.57rem);
    font-weight: 800;
    line-height: 0.94;
    margin-bottom: 1.2rem;
    letter-spacing: -0.07em;
    width: 100%;
    text-wrap: balance;
    max-width: 100%;
  }

  .hero-title span {
    display: inline;
  }

  .hero-title span:last-child {
    display: block;
  }

  .hero-description {
    font-size: 1.02rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    line-height: 1.7;
    max-width: 560px;
  }

  .hero-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .hero-highlight-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.8rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .hero-highlight-chip span {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    background: var(--gradient-1);
    box-shadow: 0 0 18px rgba(125, 249, 230, 0.45);
  }

  .hero-highlight-chip p {
    color: var(--text-soft);
    font-size: 0.92rem;
    line-height: 1.4;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .hero-buttons .btn-primary,
  .hero-buttons .btn-secondary {
    min-height: 56px;
  }

  .hero-visual {
    position: relative;
    opacity: 0.94;
  }

  .hero-visual-shell {
    position: relative;
    padding: 0 0 2rem;
  }

  .hero-dashboard {
    position: relative;
    margin: -1.1rem auto 0;
    width: min(90%, 460px);
    padding: 1.2rem;
    border-radius: 28px;
    z-index: 1;
  }

  .hero-dashboard-head {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1rem;
  }

  .hero-dashboard-head strong {
    font-size: 1rem;
  }

  @media (width < 1360px) {
    .hero-content {
      grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.75fr);
      gap: 2.5rem;
    }

    .hero-title {
      font-size: 3.15rem;
    }

    .hero-panel {
      padding: 2.2rem;
    }
  }

  .hero-signals {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .hero-signal {
    padding: 0.9rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    text-align: center;
  }

  .hero-signal strong {
    display: block;
    font-size: 1.25rem;
    margin-bottom: 0.35rem;
    color: var(--text-light);
  }

  .hero-signal span {
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.45;
  }

  @media (width < 1200px) {
    .hero-content {
      grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
      gap: 2.5rem;
    }

    .hero-title {
      font-size: 2.73rem;
    }
  }

  @media (width < 1024px) {
    .hero {
      min-height: auto;
      padding-top: 7rem;
    }

    .hero-content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-title {
      font-size: 2.38rem;
    }

    .hero-visual-shell {
      padding-bottom: 2.2rem;
    }
  }

  @media (width < 768px) {
    .hero {
      padding-top: 6.5rem;
    }

    .hero-container {
      padding-top: 1rem;
    }

    .hero-panel {
      padding: 1.3rem;
      border-radius: 24px;
    }

    .hero-title {
      font-size: 1.72rem;
    }

    .hero-badges {
      gap: 0.5rem;
    }

    .hero-description {
      font-size: 1rem;
      margin-bottom: 1.25rem;
    }

    .hero-signals {
      grid-template-columns: 1fr;
    }

    .hero-buttons {
      flex-direction: column;
    }

    .hero-buttons .btn-primary,
    .hero-buttons .btn-secondary {
      width: 100%;
    }

    .hero-visual-shell {
      padding-top: 0;
    }

    .hero-dashboard {
      width: 100%;
      margin-top: 1rem;
      padding: 1rem;
      border-radius: 22px;
    }
  }

  @media (width < 420px) {
    .hero-title {
      font-size: 1.72rem;
    }

    .hero-kicker-text,
    .hero-highlight-chip p {
      font-size: 0.92rem;
    }
  }
</style>
