---
// Bubble sort visualization component
---

<div class="sort-visualization" id="sortViz"></div>

<style>
	.sort-visualization {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		gap: 6px;
		height: 220px;
		padding: 1rem;
	}

	:global(.bar) {
		width: 24px;
		background: linear-gradient(180deg, var(--primary-light) 0%, var(--primary) 100%);
		border-radius: 4px 4px 0 0;
		transition: all 0.3s ease;
	}

	:global(.bar.comparing) {
		background: linear-gradient(180deg, #f59e0b 0%, #ef4444 100%);
	}

	:global(.bar.sorted) {
		background: linear-gradient(180deg, #34d399 0%, #10b981 100%);
	}
</style>

<script>
	function createBars(containerId: string) {
		const container = document.getElementById(containerId);
		if (!container) return null;

		const heights = [60, 140, 90, 200, 170, 100, 190, 120, 180, 80];
		container.innerHTML = "";

		heights.forEach((height) => {
			const bar = document.createElement("div");
			bar.className = "bar";
			bar.style.height = height + "px";
			container.appendChild(bar);
		});

		return {
			bars: container.querySelectorAll(".bar") as NodeListOf<HTMLElement>,
			heights: [...heights],
		};
	}

	async function bubbleSortAnimation(containerId: string) {
		const result = createBars(containerId);
		if (!result) return;

		const { bars, heights } = result;
		const n = heights.length;

		for (let i = 0; i < n; i++) {
			for (let j = 0; j < n - i - 1; j++) {
				bars[j].classList.add("comparing");
				bars[j + 1].classList.add("comparing");

				await new Promise((resolve) => setTimeout(resolve, 400));

				if (heights[j] > heights[j + 1]) {
					[heights[j], heights[j + 1]] = [heights[j + 1], heights[j]];
					bars[j].style.height = heights[j] + "px";
					bars[j + 1].style.height = heights[j + 1] + "px";
				}

				bars[j].classList.remove("comparing");
				bars[j + 1].classList.remove("comparing");
			}
			bars[n - i - 1].classList.add("sorted");
			await new Promise((resolve) => setTimeout(resolve, 200));
		}

		await new Promise((resolve) => setTimeout(resolve, 2000));
		setTimeout(() => bubbleSortAnimation(containerId), 1000);
	}

	// Start animation when DOM is ready
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", () => bubbleSortAnimation("sortViz"));
	} else {
		bubbleSortAnimation("sortViz");
	}
</script>