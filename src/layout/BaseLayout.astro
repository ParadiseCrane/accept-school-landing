---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Accept School — Курсы программирования с сильной практикой",
  description = "Изучайте программирование на собственной платформе: Основы Python, алгоритмы, Современный Python и Введение в AI. Обучение на русском или английском языке.",
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="favicon.ico" type="image/x-icon">
    <title>{title}</title>
    <link rel="canonical" href="https://accept-school.ru" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="dcde0e21-ef1a-4a7b-b561-6a5771b9ca25"></script>
    <meta property="og:title" content="Accept School — Курсы программирования с сильной практикой">
    <meta property="og:description" content="Изучайте программирование на собственной платформе: Основы Python, алгоритмы, Современный Python и Введение в AI. Обучение на русском или английском языке.">
    <meta property="og:image" content="https://accept-school.ru/og-image.jpg">
    <meta property="og:url" content="https://accept-school.ru/">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Accept School">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Accept School — Курсы программирования с сильной практикой">
    <meta name="twitter:description" content="Изучайте программирование на собственной платформе: Основы Python, алгоритмы, Современный Python и Введение в AI. Обучение на русском или английском языке.">
    <meta name="twitter:image" content="https://accept-school.ru/og-image.jpg">

    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://accept-school.ru/#organization",
      "name": "Accept School",
      "url": "https://accept-school.ru/",
      "logo": "https://accept-school.ru/logo.png",
      "sameAs": [
        "https://t.me/accept_school_bot",
        "https://github.com/ParadiseCrane"
      ],
      "description": "Онлайн-школа программирования с живой практикой, сильными курсами и собственной платформой"
    },
    {
      "@type": "Course",
      "@id": "https://accept-school.ru/#course-intro-python",
      "name": "Основы Python",
      "description": "Базовый курс по программированию на Python. Разберётесь, как устроен код, научитесь писать небольшие программы и получите хорошую основу для дальнейшего обучения.",
      "provider": {
        "@id": "https://accept-school.ru/#organization"
      },
      "url": "https://t.me/accept_school_bot",
      "educationalCredentialAwarded": "Сертификат о прохождении курса",
      "timeRequired": "PT36H",
      "teaches": [
        "Переменные, условия, циклы и функции",
        "Списки, словари, строки и базовые структуры данных",
        "Знакомство с OOP, классами и объектами",
        "Практика на учебных задачах и небольших проектах"
      ]
    },
    {
      "@type": "Course",
      "@id": "https://accept-school.ru/#course-algorithms",
      "name": "Алгоритмы и структуры данных",
      "description": "Курс для системного понимания computer science. Разберёте ключевые алгоритмы, научитесь анализировать решения и уверенно работать со структурами данных.",
      "provider": {
        "@id": "https://accept-school.ru/#organization"
      },
      "url": "https://t.me/accept_school_bot",
      "educationalCredentialAwarded": "Сертификат о прохождении курса",
      "timeRequired": "PT48H",
      "teaches": [
        "Анализ сложности алгоритмов",
        "Классические алгоритмы сортировки и поиска",
        "Работа с деревьями, графами и хеш-таблицами",
        "Динамическое программирование"
      ]
    },
    {
      "@type": "Course",
      "@id": "https://accept-school.ru/#course-python",
      "name": "Современный Python",
      "description": "Курс по современному Python и актуальным инструментам разработки. Освоите рабочий стек и подходы, которые используются в реальных проектах.",
      "provider": {
        "@id": "https://accept-school.ru/#organization"
      },
      "url": "https://t.me/accept_school_bot",
      "educationalCredentialAwarded": "Сертификат о прохождении курса",
      "timeRequired": "PT48H",
      "teaches": [
        "Современные инструменты разработки (uv, ruff)",
        "Type hints и статическая типизация (ty)",
        "FastAPI и асинхронное программирование",
        "Проектирование API и серверной логики",
        "Реальные проекты и code review"
      ]
    },
    {
      "@type": "Course",
      "@id": "https://accept-school.ru/#course-ai",
      "name": "Введение в AI",
      "description": "Вводный курс по основам искусственного интеллекта. Узнаете, как алгоритмы ищут решения, обучаются на данных и принимают решения на основе моделей.",
      "provider": {
        "@id": "https://accept-school.ru/#organization"
      },
      "url": "https://t.me/accept_school_bot",
      "educationalCredentialAwarded": "Сертификат о прохождении курса",
      "timeRequired": "PT36H",
      "teaches": [
        "Search algorithms и поиск оптимального решения",
        "Evolutionary programming и идеи эволюции в вычислениях",
        "Supervised learning на понятных примерах",
        "Unsupervised learning и поиск скрытых закономерностей",
        "Decision trees и базовые модели принятия решений"
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://accept-school.ru/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Какой уровень подготовки нужен для начала?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Для курса 'Основы Python' специальная подготовка не нужна: можно начинать с нуля. Для 'Алгоритмов и структур данных' желательно знать основы любого языка программирования. 'Современный Python' подойдёт тем, кто уже пробовал писать код и хочет перейти к более системной практике."
          }
        },
        {
          "@type": "Question",
          "name": "Как проходят занятия на English Track?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Все основные занятия проводятся полностью на английском языке. Дополнительно проводятся групповые встречи для развития разговорных навыков и технического английского. Преподаватель помогает адаптироваться к формату и уверенно работать на английском языке."
          }
        },
        {
          "@type": "Question",
          "name": "Как работает Accept Platform?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Accept Platform — это наша собственная система для отправки и проверки решений. Вы пишете код прямо в браузере, отправляете на проверку и мгновенно получаете результаты. Платформа доступна 24/7 и работает с любого устройства."
          }
        },
        {
          "@type": "Question",
          "name": "Какой формат обучения?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Обучение проходит в формате онлайн-занятий с преподавателем и самостоятельной работы на платформе. Каждый урок включает теоретическую часть, разбор примеров и практические задания. Доступ к материалам и платформе сохраняется после окончания курса."
          }
        },
        {
          "@type": "Question",
          "name": "Можно ли проходить несколько курсов одновременно?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да, такая возможность есть. При этом совмещать несколько курсов может быть непросто: требуется время на занятия, домашние задания и практику. Если вы сомневаетесь, напишите нам в Telegram-бот, и мы поможем выбрать комфортный темп обучения."
          }
        }
      ]
    }
  ]
}
</script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --primary: #14b8a6;
    --primary-dark: #0f766e;
    --primary-light: #7df9e6;
    --secondary: #fb923c;
    --accent: #bef264;
    --accent-cyan: #38bdf8;
    --bg-dark: #09131d;
    --bg-darker: #040b12;
    --surface-1: rgba(9, 19, 29, 0.84);
    --surface-2: rgba(12, 26, 39, 0.92);
    --surface-3: rgba(17, 35, 51, 0.7);
    --text-light: #f4fbff;
    --text-muted: #9ab1c6;
    --text-soft: rgba(244, 251, 255, 0.74);
    --border: rgba(226, 232, 240, 0.12);
    --border-strong: rgba(125, 249, 230, 0.18);
    --code-bg: #132231;
    --card-bg: rgba(10, 22, 34, 0.78);
    --shadow-soft: 0 24px 70px rgba(1, 6, 12, 0.34);
    --shadow-card: 0 28px 90px rgba(0, 0, 0, 0.28);
    --gradient-1: linear-gradient(135deg, #14b8a6 0%, #38bdf8 100%);
    --gradient-2: linear-gradient(135deg, #fb923c 0%, #facc15 100%);
    --gradient-3: linear-gradient(135deg, #bef264 0%, #2dd4bf 100%);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family:
      "Space Grotesk",
      -apple-system,
      sans-serif;
    background:
      radial-gradient(circle at 0% 0%, rgba(56, 189, 248, 0.14), transparent 26%),
      radial-gradient(circle at 100% 5%, rgba(251, 146, 60, 0.14), transparent 24%),
      radial-gradient(circle at 50% 100%, rgba(20, 184, 166, 0.12), transparent 30%),
      linear-gradient(180deg, #06111a 0%, #040b12 42%, #08131d 100%);
    color: var(--text-light);
    line-height: 1.6;
    overflow-x: hidden;
    min-height: 100vh;
    position: relative;
  }

  body::before,
  body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }

  body::before {
    background:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image:
      linear-gradient(180deg, rgba(0, 0, 0, 0.82), rgba(0, 0, 0, 0.2) 55%, transparent),
      radial-gradient(circle at center, black, transparent 86%);
  }

  body::after {
    background:
      radial-gradient(circle at 12% 18%, rgba(34, 211, 238, 0.12), transparent 22%),
      radial-gradient(circle at 85% 8%, rgba(251, 146, 60, 0.12), transparent 18%),
      radial-gradient(circle at 50% 50%, rgba(20, 184, 166, 0.06), transparent 28%);
    filter: blur(46px);
  }

  .container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section {
    padding: 7.5rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4.5rem;
  }

  .section-header h2 {
    font-size: clamp(2.7rem, 5vw, 4.4rem);
    font-weight: 800;
    margin-bottom: 1.1rem;
    letter-spacing: -0.05em;
    text-wrap: balance;
    line-height: 0.98;
  }

  .section-header p {
    font-size: 1.08rem;
    color: var(--text-muted);
    margin: 0 auto;
    max-width: 780px;
    line-height: 1.85;
  }

  .section-header-secondary h3 {
    font-size: clamp(2.1rem, 4vw, 3.3rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .section-header-secondary p {
    font-size: 1.05rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    line-height: 1.85;
  }

  .gradient-text {
    background: var(--gradient-1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .btn-primary,
  .btn-secondary {
    color: var(--text-light);
    padding: 1rem 1.8rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.98rem;
    letter-spacing: 0.01em;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease,
      background 0.3s ease,
      filter 0.3s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .btn-primary {
    background: var(--gradient-1);
    border: 1px solid rgba(125, 249, 230, 0.2);
    box-shadow: 0 20px 42px rgba(20, 184, 166, 0.24);
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 48px rgba(20, 184, 166, 0.32);
    filter: saturate(1.06);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.09);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 10px 30px rgba(0, 0, 0, 0.18);
  }

  .btn-secondary:hover {
    transform: translateY(-3px);
    border-color: rgba(94, 234, 212, 0.4);
    background: rgba(255, 255, 255, 0.07);
  }

  ::selection {
    background: rgba(34, 211, 238, 0.28);
    color: var(--text-light);
  }

  .surface-card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      var(--shadow-soft);
    backdrop-filter: blur(18px);
  }

  .eyebrow-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary-light);
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
  }

  .eyebrow-link::after {
    content: "→";
    transition: transform 0.25s ease;
  }

  .eyebrow-link:hover::after {
    transform: translateX(4px);
  }

  @media (width < 1024px) {
    .section {
      padding: 4.5rem 0;
    }
  }

  @media (width < 768px) {
    .container {
      padding: 0 1rem;
    }

    .section-header h2 {
      font-size: 2.2rem;
    }

    .section-header p {
      font-size: 1rem;
    }

    .section-header-secondary h3 {
      font-size: 1.5rem;
      font-weight: 800;
      margin-bottom: 1rem;
      line-height: 1.5;
    }

    .section-header-secondary p {
      font-size: 1rem;
      line-height: 1.5;
      margin-bottom: 1rem;
    }

    .btn-primary,
    .btn-secondary {
      padding: 0.95rem 1.2rem;
      font-size: 0.9rem;
    }
  }
</style>
